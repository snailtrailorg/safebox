<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sign_in_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:gravity="center_horizontal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/sign_in_form_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/general_margin_small"
                android:layout_marginLeft="@dimen/general_margin_small"
                android:layout_marginRight="@dimen/general_margin_small"
                android:layout_marginBottom="@dimen/general_margin_tiny"
                android:gravity="center_horizontal"
                android:text="@string/sign_in_form_title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/general_margin_tiny"
                android:layout_marginLeft="@dimen/general_margin_small"
                android:layout_marginRight="@dimen/general_margin_small"
                android:layout_marginBottom="@dimen/general_margin_tiny">

            <AutoCompleteTextView
                    android:id="@+id/sign_in_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/sign_in_prompt_email"
                    android:imeOptions="actionNext"
                    android:inputType="textEmailAddress"
                    android:maxLength="50"
                    android:maxLines="1"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/general_margin_tiny"
                android:layout_marginLeft="@dimen/general_margin_small"
                android:layout_marginRight="@dimen/general_margin_small"
                android:layout_marginBottom="@dimen/general_margin_tiny">

                <EditText
                    android:id="@+id/sign_in_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/sign_in_prompt_password"
                    android:imeOptions="actionNext"
                    android:importantForAutofill="no"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:nextFocusForward="@id/sign_in_sign_in"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start">

                    <Button
                        android:id="@+id/sign_in_switch_sign_up"
                        style="?android:textAppearanceSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/general_margin_small"
                        android:layout_marginTop="@dimen/general_margin_tiny"
                        android:layout_marginEnd="@dimen/general_margin_tiny"
                        android:layout_marginBottom="@dimen/general_margin_small"
                        android:text="@string/sign_in_prompt_switch_sign_up"
                        android:textAllCaps="false" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end">

                    <Button
                        android:id="@+id/sign_in_sign_in"
                        style="?android:textAppearanceSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/general_margin_tiny"
                        android:layout_marginTop="@dimen/general_margin_tiny"
                        android:layout_marginEnd="@dimen/general_margin_small"
                        android:layout_marginBottom="@dimen/general_margin_small"
                        android:text="@string/sign_in_prompt_sign_in"
                        android:textAllCaps="false"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/sign_in_progress_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/general_margin_small"
                android:layout_marginLeft="@dimen/general_margin_small"
                android:layout_marginRight="@dimen/general_margin_small"
                android:layout_marginBottom="@dimen/general_margin_tiny"
                android:gravity="center_horizontal"
                android:text="@string/sign_in_progress_title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ProgressBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/general_margin_small"
                    android:layout_marginTop="@dimen/general_margin_tiny"
                    android:layout_marginEnd="@dimen/general_margin_tiny"
                    android:layout_marginBottom="@dimen/general_margin_small" />

                <TextView
                    android:id="@+id/sign_in_progress_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/general_margin_tiny"
                    android:layout_marginTop="@dimen/general_margin_tiny"
                    android:layout_marginEnd="@dimen/general_margin_small"
                    android:layout_marginBottom="@dimen/general_margin_small"
                    android:text="@string/sign_in_progress_processing_message" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>