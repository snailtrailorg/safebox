<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/general_margin_mini"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:text="@string/icon_list_dialog_title"
        android:textSize="20sp"
        android:textStyle="bold" />

    <GridView
        android:id="@+id/icon_list_dialog_grid_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center_horizontal"
        android:layout_weight="10"
        android:columnWidth="@dimen/app_icon_size_medium"
        android:horizontalSpacing="@dimen/general_margin_tiny"
        android:numColumns="auto_fit"
        android:verticalSpacing="@dimen/general_margin_tiny">

    </GridView>

    <Button
        android:id="@+id/icon_list_dialog_button_cancel"
        style="?android:textAppearanceSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/icon_list_dialog_button_cancel"
        android:textAllCaps="false"
        android:textStyle="bold" />

</LinearLayout>