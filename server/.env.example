# SafeBox 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ── 数据库 ──────────────────────────────────────
SAFEBOX_DATABASE_URL=postgresql+asyncpg://safebox:safebox@localhost:5432/safebox

# ── JWT (用 openssl rand -hex 32 生成) ─────────
SAFEBOX_JWT_SECRET_KEY=change-me-to-random-64-chars-hex

# ── Redis ───────────────────────────────────────
SAFEBOX_REDIS_URL=redis://localhost:6379/0

# ── 短信 (Twilio) ───────────────────────────────
SAFEBOX_TWILIO_ACCOUNT_SID=
SAFEBOX_TWILIO_AUTH_TOKEN=
SAFEBOX_TWILIO_PHONE_NUMBER=+1234567890

# ── 邮件 ────────────────────────────────────────
SAFEBOX_SMTP_HOST=
SAFEBOX_SMTP_PORT=587
SAFEBOX_SMTP_USERNAME=
SAFEBOX_SMTP_PASSWORD=
SAFEBOX_SMTP_FROM=noreply@safebox.example.com

# ── Google OAuth ────────────────────────────────
SAFEBOX_GOOGLE_CLIENT_ID=

# ── 同步 ────────────────────────────────────────
SAFEBOX_SYNC_BATCH_LIMIT=100
